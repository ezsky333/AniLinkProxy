PORT=8080
UPSTREAM_BASE_URL=https://api.dandanplay.net
UPSTREAM_DANDAN_APP_ID=your_upstream_app_id
UPSTREAM_DANDAN_APP_SECRET=your_upstream_app_secret
JWT_SECRET=change-this-value-at-least-32-chars-long
SQLITE_PATH=./backend/data/proxy.db

# 可选：32 字节随机密钥的 base64，用于加密落库的 AppSecret；不配置则明文存储（兼容旧库）
# SECRET_WRAP_KEY=

# HTTPS 生产环境建议 true，使会话 Cookie 带 Secure
# AUTH_COOKIE_SECURE=true

# 管理台与 API 跨域时必填，例如本机 Vite 前端：http://localhost:5175
# ADMIN_ALLOWED_ORIGIN=http://localhost:5175

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_ADDRESS=noreply@example.com

TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=ChangeMe_123456
